OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail_address@gmail.com
SMTP_PASSWORD=your_gmail_app_password
EMAIL_FROM=your_gmail_address@gmail.com
EMAIL_TO=approver_email@gmail.com

IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=your_gmail_address@gmail.com
IMAP_PASSWORD=your_gmail_app_password

LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_with_openid_profile_w_member_social
LINKEDIN_AUTHOR_URN=urn:li:person:your_userinfo_sub_value
LINKEDIN_API_VERSION=202604

STORAGE_FILE=storage.json
MAX_REGEN_ATTEMPTS=3
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log
LOG_MAX_BYTES=2097152
LOG_BACKUP_COUNT=5
